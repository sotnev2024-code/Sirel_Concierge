# Пример юнита systemd для Sirel_Concierge (Telegram + Max через start.py).
#
# Быстрая установка (VPS, root, путь /root/Sirel_Concierge):
#   cd /root/Sirel_Concierge && git pull && sudo bash deploy/install-systemd.sh
#
# Вручную:
#   1) sudo cp deploy/sirel-bots.service.example /etc/systemd/system/sirel-bots.service
#   2) Отредактируйте User, WorkingDirectory, ExecStart.
#   3) sudo systemctl daemon-reload && sudo systemctl enable --now sirel-bots.service
#
# Готовый юнит под root: deploy/sirel-bots.service
#
# Логи: journalctl -u sirel-bots.service -f

[Unit]
Description=Sirel Telegram + Max bots (start.py)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=ubuntu
Group=ubuntu
WorkingDirectory=/home/ubuntu/Sirel_Concierge

# venv Python первым в PATH
Environment=PATH=/home/ubuntu/Sirel_Concierge/.venv/bin:/usr/local/bin:/usr/bin:/bin

ExecStart=/home/ubuntu/Sirel_Concierge/.venv/bin/python3 start.py

# Перезапуск при падении и при необработанных исключениях (процесс завершился)
Restart=always
RestartSec=15

# Не крутить бесконечный цикл при поломанной конфигурации (опционально)
StartLimitIntervalSec=300
StartLimitBurst=5

# Корректная остановка
KillSignal=SIGTERM
TimeoutStopSec=30

[Install]
WantedBy=multi-user.target
