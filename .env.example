BOT_TOKEN=your_telegram_bot_token_here
MAX_BOT_TOKEN=your_max_bot_token_here
ADMIN_IDS=12345678,98765432

# Telegram channel
CHANNEL_ID=@your_channel_username
CHANNEL_URL=https://t.me/your_channel_link

# Max community/channel (chat_id — numeric ID; link from community settings)
MAX_CHANNEL_ID=123456789
MAX_CHANNEL_URL=https://max.ru/join/your_community_link

# Тестовый терминал эквайринга (Т-Банк и т.п.): ID и пароль из раздела «Терминалы» → Тестовый.
# Если в пароле есть # — обязательно в двойных кавычках.
# PAYMENT_TERMINAL_ID=1774620399694DEMO
# PAYMENT_TERMINAL_PASSWORD="your_password_here"
