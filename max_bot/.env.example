MAX_BOT_TOKEN=your_max_bot_token_here
# Тот же токен, что в корневом .env — для кросс-постинга в Telegram из админки Max
BOT_TOKEN=
TELEGRAM_CHANNEL_ID=
ADMIN_IDS=12345678,98765432

# Max community/channel (public id for posting: often ends with _biz; link for subscribe button)
MAX_CHANNEL_ID=123456789_biz
MAX_CHANNEL_URL=https://max.ru/id123456789_biz

# Integer chat id for membership check GET /chats/{chatId}/members (from bot_added update in logs, or omit if getChatByLink works)
MAX_GROUP_CHAT_ID=

# Relative path to shared SQLite DB (from max_bot/ directory)
DB_PATH=../data/bot_database.db
